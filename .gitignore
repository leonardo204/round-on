
# Secrets — NEVER commit
.env
.env.local
*.local
.api-keys
.api-keys.*
Secrets.plist
Secrets.xcconfig
secrets/

# Claude Code runtime
.claude/db/context.db
.claude/db/context.db-shm
.claude/db/context.db-wal
.claude/.ctx_state
.claude/.backup-*
.claude/.ralph_state
.claude/.hud_cache
.claude/.hook_feedback
.claude/.project_root
.claude/.messenger_enabled
.claude/scheduled_tasks.lock

# macOS Finder
.DS_Store
**/.DS_Store

# Xcode generated
# .xcodeproj/.xcworkspace는 commit (XcodeGen이 재생성하지만 IDE 진입점 편의)
# 단 사용자별 상태(xcuserdata/xcuserstate)는 제외
xcuserdata/
*.xcuserstate
DerivedData/
build/
.build/
*.dSYM
.swiftpm/

# 로컬 목업 자산 (커밋 노이즈 회피)
.mockups/

# Kakao API cache (재빌드 가능)
ref-docs/golf-db-pack/.kakao_cache.json
ref-docs/golf-db-pack/.kakao_html_cache/
ref-docs/golf-db-pack/.naver_html_cache/
ref-docs/golf-db-pack/.naver_holes_cache/

# Python
__pycache__/
*.pyc

# Build backups
*.json.bak
*.json.bak[0-9]*
*.bak

# 로컬 테스트 자산 (개인정보 포함 가능 — 커밋 금지)
samples/

# OCR 벤치 sandbox (제거된 기능 — 향후 참조용 로컬 유지)
test-bed/

# 임시 스크린샷 (커밋 노이즈 회피)
